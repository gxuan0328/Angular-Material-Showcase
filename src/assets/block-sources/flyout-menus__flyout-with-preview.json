{
  "category": "flyout-menus",
  "variant": "flyout-with-preview",
  "files": {
    "flyout-with-preview.component.html": "<!--\n\tInstalled from https://ui.angular-material.dev/\n\tUpdate this file using `npx @ngm-dev/cli update flyout-menus/flyout-with-preview`\n-->\n\n<mat-sidenav-container class=\"h-[500px] md:h-auto\">\n  <mat-sidenav\n    #mobileSidenav\n    mode=\"over\"\n    position=\"end\"\n    [opened]=\"mobileMenuOpen()\"\n    (closed)=\"mobileMenuOpen.set(false)\"\n  >\n    <!-- Mobile Menu Header -->\n    <mat-toolbar class=\"sticky top-0 bg-inherit z-10\">\n      <span class=\"text-xl font-bold\">Preview</span>\n      <button\n        type=\"button\"\n        mat-icon-button\n        (click)=\"toggleMobileMenu()\"\n        aria-label=\"Close menu\"\n        class=\"ml-auto\"\n      >\n        <mat-icon>close</mat-icon>\n      </button>\n    </mat-toolbar>\n\n    <!-- Mobile Menu Content -->\n    <div class=\"flex-1 p-4\">\n      <p class=\"text-title-medium font-title-medium\">Products</p>\n      <mat-nav-list>\n        @for (item of productItems; track item.label) {\n        <a mat-list-item [href]=\"item.href\">\n          <mat-icon matListItemIcon>{{ item.icon }}</mat-icon>\n          <div matListItemTitle>{{ item.label }}</div>\n          <!-- prettier-ignore -->\n          <div\n              matListItemLine\n              class=\"text-xs! text-gray-600! dark:text-gray-400!\">{{ item.description }}</div>\n        </a>\n        }\n      </mat-nav-list>\n\n      <!-- Featured Product -->\n      <div class=\"mt-4 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg\">\n        <h3 class=\"text-sm font-semibold mb-2 text-gray-900 dark:text-white\">\n          Featured\n        </h3>\n        <a [href]=\"featuredProduct.href\" class=\"block group\">\n          <div class=\"relative overflow-hidden rounded-lg mb-2\">\n            <img\n              [src]=\"featuredProduct.image\"\n              [alt]=\"featuredProduct.title\"\n              class=\"w-full aspect-[4/3] object-cover\"\n            />\n          </div>\n          <h4 class=\"text-sm font-semibold mb-1 group-hover:text-primary\">\n            {{ featuredProduct.title }}\n          </h4>\n          <p class=\"text-xs text-gray-600 dark:text-gray-400 mb-2\">\n            {{ featuredProduct.description }}\n          </p>\n          <span\n            class=\"text-xs font-semibold text-primary inline-flex items-center gap-1\"\n          >\n            {{ featuredProduct.label }}\n            <mat-icon class=\"text-base! leading-none! size-[1em]!\"\n              >arrow_forward</mat-icon\n            >\n          </span>\n        </a>\n      </div>\n\n      <p class=\"text-title-medium font-title-medium mt-4\">Blog</p>\n      <mat-nav-list>\n        @for (post of blogPosts; track post.title) {\n        <a mat-list-item [href]=\"post.href\">\n          <img\n            matListItemAvatar\n            [src]=\"post.image\"\n            [alt]=\"post.title\"\n            class=\"object-cover\"\n          />\n          <div matListItemTitle>{{ post.title }}</div>\n          <!-- prettier-ignore -->\n          <div\n              matListItemLine\n              class=\"text-gray-600! dark:text-gray-400!\">{{ post.description }}</div>\n        </a>\n        }\n      </mat-nav-list>\n\n      <mat-divider></mat-divider>\n      <mat-nav-list>\n        <a mat-list-item href=\"#\">Pricing</a>\n        <a mat-list-item href=\"#\">Contact</a>\n      </mat-nav-list>\n    </div>\n\n    <!-- Mobile Menu Footer -->\n    <div class=\"p-4 border-t border-outline-variant space-y-2\">\n      <button type=\"button\" matButton=\"text\" class=\"w-full\">Sign in</button>\n      <button type=\"button\" matButton=\"filled\" class=\"w-full\">\n        Get started\n      </button>\n    </div>\n  </mat-sidenav>\n\n  <mat-sidenav-content>\n    <mat-toolbar class=\"border-b border-outline-variant justify-between\">\n      <!-- Logo -->\n      <span class=\"text-xl font-bold\">Preview</span>\n\n      @if (isLessThanMD()) {\n      <button\n        type=\"button\"\n        mat-icon-button\n        (click)=\"toggleMobileMenu()\"\n        aria-label=\"Open menu\"\n      >\n        <mat-icon>menu</mat-icon>\n      </button>\n      } @else {\n      <!-- Navigation Links -->\n      <div class=\"flex items-center space-x-1\">\n        <!-- Products Menu with Featured -->\n        <button\n          type=\"button\"\n          matButton\n          cdkOverlayOrigin\n          #productsTrigger=\"cdkOverlayOrigin\"\n          (click)=\"productsOverlay.toggleOverlay()\"\n          [class]=\"productsOverlay.isOpen() ? 'bg-primary-container!' : ''\"\n        >\n          Products\n          <mat-icon>expand_more</mat-icon>\n        </button>\n\n        <ngm-dev-block-ui-overlay-wrapper\n          #productsOverlay\n          [trigger]=\"productsTrigger\"\n        >\n          <div\n            class=\"bg-white dark:bg-gray-900 rounded-lg shadow-lg ring-1 ring-black/5 dark:ring-white/10 overflow-hidden w-[640px]\"\n          >\n            <div class=\"grid grid-cols-2\">\n              <!-- Products List -->\n              <div class=\"p-6\">\n                <h3\n                  class=\"text-sm font-semibold mb-4 text-gray-900 dark:text-white\"\n                >\n                  Our Products\n                </h3>\n                <mat-nav-list>\n                  @for (item of productItems; track item.label) {\n                  <a mat-list-item [href]=\"item.href\">\n                    <mat-icon matListItemIcon class=\"text-primary!\">\n                      {{ item.icon }}\n                    </mat-icon>\n                    <div matListItemTitle>{{ item.label }}</div>\n                    <!-- prettier-ignore -->\n                    <p\n                          matListItemLine\n                          class=\"text-xs! text-gray-600! dark:text-gray-400!\">{{ item.description }}</p>\n                  </a>\n                  }\n                </mat-nav-list>\n              </div>\n\n              <!-- Featured Product -->\n              <div class=\"bg-gray-50 dark:bg-gray-800 p-6\">\n                <h3\n                  class=\"text-sm font-semibold mb-4 text-gray-900 dark:text-white\"\n                >\n                  Featured\n                </h3>\n                <a\n                  [href]=\"featuredProduct.href\"\n                  (click)=\"productsOverlay.close()\"\n                  class=\"block group\"\n                >\n                  <div class=\"relative overflow-hidden rounded-lg mb-3\">\n                    <img\n                      [src]=\"featuredProduct.image\"\n                      [alt]=\"featuredProduct.title\"\n                      class=\"w-full aspect-[4/3] object-cover\"\n                    />\n                  </div>\n                  <h4 class=\"text-sm font-semibold mb-1\">\n                    {{ featuredProduct.title }}\n                  </h4>\n                  <p class=\"text-xs text-gray-600 dark:text-gray-400 mb-2\">\n                    {{ featuredProduct.description }}\n                  </p>\n                  <span\n                    class=\"text-xs font-semibold text-primary inline-flex items-center gap-1\"\n                  >\n                    {{ featuredProduct.label }}\n                    <mat-icon class=\"text-base! leading-none! size-[1em]!\"\n                      >arrow_forward</mat-icon\n                    >\n                  </span>\n                </a>\n              </div>\n            </div>\n          </div>\n        </ngm-dev-block-ui-overlay-wrapper>\n\n        <!-- Blog Menu with Posts -->\n        <button\n          type=\"button\"\n          matButton\n          cdkOverlayOrigin\n          #blogTrigger=\"cdkOverlayOrigin\"\n          (click)=\"blogOverlay.toggleOverlay()\"\n          [class]=\"blogOverlay.isOpen() ? 'bg-primary-container!' : ''\"\n        >\n          Blog\n          <mat-icon>expand_more</mat-icon>\n        </button>\n\n        <ngm-dev-block-ui-overlay-wrapper #blogOverlay [trigger]=\"blogTrigger\">\n          <div\n            class=\"bg-white dark:bg-gray-900 rounded-lg shadow-lg ring-1 ring-black/5 dark:ring-white/10 p-6\"\n          >\n            <div class=\"w-[400px]\">\n              <h3\n                class=\"text-sm font-semibold mb-4 text-gray-900 dark:text-white\"\n              >\n                Recent Posts\n              </h3>\n              <div class=\"space-y-3\">\n                @for (post of blogPosts; track post.title) {\n                <a\n                  [href]=\"post.href\"\n                  (click)=\"blogOverlay.close()\"\n                  class=\"flex gap-4 rounded-lg p-3 hover:bg-gray-100 dark:hover:bg-gray-800 group\"\n                >\n                  <div class=\"relative overflow-hidden rounded-lg shrink-0\">\n                    <img\n                      [src]=\"post.image\"\n                      [alt]=\"post.title\"\n                      class=\"w-24 h-16 object-cover\"\n                    />\n                  </div>\n                  <div class=\"flex-1 min-w-0\">\n                    <h4\n                      class=\"text-sm font-semibold mb-1 group-hover:text-primary\"\n                    >\n                      {{ post.title }}\n                    </h4>\n                    <p class=\"text-xs text-gray-600 dark:text-gray-400 mb-2\">\n                      {{ post.description }}\n                    </p>\n                    <span\n                      class=\"text-xs font-semibold text-primary inline-flex items-center gap-1\"\n                    >\n                      {{ post.label }}\n                      <mat-icon class=\"text-base! leading-none! size-[1em]!\"\n                        >arrow_forward</mat-icon\n                      >\n                    </span>\n                  </div>\n                </a>\n                }\n              </div>\n              <div\n                class=\"mt-4 pt-4 border-t border-gray-200 dark:border-gray-700\"\n              >\n                <a\n                  href=\"#\"\n                  (click)=\"blogOverlay.close()\"\n                  matButton\n                  class=\"inline-flex items-center gap-1 hover:gap-2 transition-all\"\n                >\n                  View all posts\n                  <mat-icon iconPositionEnd>arrow_forward</mat-icon>\n                </a>\n              </div>\n            </div>\n          </div>\n        </ngm-dev-block-ui-overlay-wrapper>\n\n        <!-- Regular Links -->\n        <a href=\"#\" matButton> Pricing </a>\n        <a href=\"#\" matButton> Contact </a>\n      </div>\n\n      <!-- CTA Buttons -->\n      <div class=\"flex items-center space-x-2\">\n        <button type=\"button\" matButton=\"text\">Sign in</button>\n        <button type=\"button\" matButton=\"filled\">Get started</button>\n      </div>\n      }\n    </mat-toolbar>\n  </mat-sidenav-content>\n</mat-sidenav-container>\n",
    "flyout-with-preview.component.ts": "/*\n\tInstalled from https://ui.angular-material.dev/\n\tUpdate this file using `npx @ngm-dev/cli update flyout-menus/flyout-with-preview`\n*/\n\nimport { CdkOverlayOrigin } from '@angular/cdk/overlay';\nimport {\n  ChangeDetectionStrategy,\n  Component,\n  signal,\n  inject,\n} from '@angular/core';\nimport { toSignal } from '@angular/core/rxjs-interop';\n\nimport { MatButtonModule } from '@angular/material/button';\nimport { MatIconModule } from '@angular/material/icon';\nimport { MatSidenavModule } from '@angular/material/sidenav';\nimport { MatListModule } from '@angular/material/list';\nimport { MatToolbar } from '@angular/material/toolbar';\nimport { MatDivider } from '@angular/material/divider';\nimport { DeviceService } from '../../utils/services/device.service';\nimport { OverlayWrapperComponent } from '../../wrappers/overlay-wrapper/overlay-wrapper.component';\n\ntype ProductItem = {\n  icon: string;\n  label: string;\n  description: string;\n  href: string;\n};\n\ntype FeaturedContent = {\n  title: string;\n  description: string;\n  image: string;\n  href: string;\n  label: string;\n};\n\n@Component({\n  selector: 'ngm-dev-block-flyout-with-preview',\n  templateUrl: './flyout-with-preview.component.html',\n  changeDetection: ChangeDetectionStrategy.OnPush,\n  imports: [\n    MatButtonModule,\n    MatIconModule,\n    MatSidenavModule,\n    MatListModule,\n    MatToolbar,\n    MatDivider,\n    CdkOverlayOrigin,\n    OverlayWrapperComponent,\n  ],\n})\nexport class FlyoutWithPreviewComponent {\n  readonly mobileMenuOpen = signal(false);\n  readonly isLessThanMD = toSignal(inject(DeviceService).isLessThanMD$);\n\n  toggleMobileMenu(): void {\n    this.mobileMenuOpen.update((value) => !value);\n  }\n\n  productItems: ProductItem[] = [\n    {\n      icon: 'analytics',\n      label: 'Analytics Engine',\n      description: 'Advanced data analysis tools',\n      href: '#',\n    },\n    {\n      icon: 'security',\n      label: 'Security Suite',\n      description: 'Enterprise-grade protection',\n      href: '#',\n    },\n    {\n      icon: 'cloud_sync',\n      label: 'Cloud Sync',\n      description: 'Seamless data synchronization',\n      href: '#',\n    },\n    {\n      icon: 'monitoring',\n      label: 'Real-time Monitor',\n      description: 'Track performance metrics',\n      href: '#',\n    },\n  ];\n\n  featuredProduct: FeaturedContent = {\n    title: 'New Feature Release',\n    description:\n      'Discover our latest AI-powered analytics dashboard with enhanced visualization capabilities.',\n    image: 'https://placehold.co/400x300/6366f1/ffffff?text=Featured',\n    href: '#',\n    label: 'Learn more',\n  };\n\n  blogPosts: FeaturedContent[] = [\n    {\n      title: 'Building Scalable Applications',\n      description: 'Best practices for modern web development',\n      image: 'https://placehold.co/300x200/8b5cf6/ffffff?text=Post+1',\n      href: '#',\n      label: 'Read article',\n    },\n    {\n      title: 'Security Best Practices',\n      description: 'Protecting your data in the cloud era',\n      image: 'https://placehold.co/300x200/ec4899/ffffff?text=Post+2',\n      href: '#',\n      label: 'Read article',\n    },\n  ];\n}\n"
  }
}